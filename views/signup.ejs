<!DOCTYPE html>
<html>
<head>
    <title>Signup</title>
</head>
<body>

<h1>Signup</h1>

<form action="/user/signup" method="POST">

    <input
        type="text"
        name="name"
        placeholder="Enter Name"
        required
    >

    <br><br>

    <input
        type="email"
        name="email"
        placeholder="Enter Email"
        required
    >

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="Enter Password"
        required
    >

    <br><br>

    <button type="submit">
        Signup
    </button>

</form>

</body>
</html>